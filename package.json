{
  "name": "iGaia",
  "author": "Extract Plug",
  "productName": "iGaia",
  "version": "1.0.0",
  "description": "Gaia Online Native Flash Client built by Extract Plug",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "9.4.4",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.igaia.client",
    "productName": "iGaia",
	"asar": true,
	"asarUnpack": ["plugins/**"],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "gaia-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "iGaia-Portable.exe"
    },
    "files": [
      "**/*",
      "!node_modules/electron/dist/*",
      "plugins/pepflashplayer64.dll"
    ],
    "extraFiles": [
      {
        "from": "plugins",
        "to": "plugins",
        "filter": ["**/*"]
      }
    ]
  }
}